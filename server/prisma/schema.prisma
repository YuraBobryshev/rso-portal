// Настройки подключения
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 1. ВСЕ НАШИ РОЛИ
enum Role {
  USER 
  CANDIDATE 
  BOETS 
  COMMANDER 
  COMMISSAR 
  MASTER 
  MEDIA 
  REG_HQ 
}

// 2. МОДЕЛЬ ПОЛЬЗОВАТЕЛЯ
model User {
  id             String             @id @default(uuid())
  email          String             @unique
  password       String?
  firstName      String
  lastName       String
  role           Role               @default(USER)
  avatarUrl      String?
  vkUrl          String?            @default("")
  tgUrl          String?            @default("")
  
  // НОВОЕ: ID пользователя ВКонтакте для отправки API-уведомлений
  vkId           String?
  googleId  String?  @unique
  yandexId  String?  @unique            

  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  brigadeId      String?
  brigade        Brigade?           @relation(fields: [brigadeId], references: [id])
  applications   Application[]
  achievements   Achievement[]
  participations EventParticipant[]
  posts          Post[] 
  comments       Comment[] 
}

model Brigade {
  id           String        @id @default(uuid())
  name         String        @unique
  description  String        @db.Text
  type         String 
  logoUrl      String?
  colorScheme  String?       @default("#0804FF") 
  
  // НОВОЕ: ID беседы комсостава в ВК, куда бот будет присылать новые анкеты
  vkChatId     String?       

  createdAt    DateTime      @default(now())
  users        User[]
  applications Application[]
  events       Event[]
  achievements Achievement[]
  
  // НОВОЕ: Связь с трудовыми объектами (один отряд может работать на многих объектах)
  laborObjects LaborObject[] 
}

// НОВОЕ: Статус CANCELED для самостоятельной отмены заявки бойцом
enum AppStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELED
}

// Модель заявки
model Application {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  brigadeId String
  brigade   Brigade   @relation(fields: [brigadeId], references: [id])
  status    AppStatus @default(PENDING)
  comment   String?
  createdAt DateTime  @default(now())
}

// НОВОЕ: Модель Трудовых объектов
model LaborObject {
  id          String    @id @default(uuid())
  name        String    // Например: "Mriya Resort & SPA 5*"
  location    String    // Например: "Ялта, Крым"
  task        String    @db.Text // Описание производственной задачи
  imageUrl    String?   // Фотография объекта
  createdAt   DateTime  @default(now())

  // Связь: На этом объекте могут работать сразу несколько отрядов
  brigades    Brigade[] 
}

model Event {
  id             String             @id @default(uuid())
  title          String
  description    String?
  date           DateTime
  location       String?
  type           String             @default("LOCAL") 
  brigadeId      String?
  brigade        Brigade?           @relation(fields: [brigadeId], references: [id])
  createdAt      DateTime           @default(now())
  participations EventParticipant[]
}

// ОБНОВЛЕНО: Расширена модель достижений для системы грамот
model Achievement {
  id          String   @id @default(uuid())
  title       String
  description String?  // НОВОЕ: За что выдана грамота
  imageUrl    String?  // Скан или дизайн грамоты
  value       Int      @default(1) 
  issuedAt    DateTime @default(now()) // НОВОЕ: Дата выдачи
  
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  brigadeId String?
  brigade   Brigade? @relation(fields: [brigadeId], references: [id])
}

model EventParticipant {
  id       String  @id @default(uuid())
  userId   String
  user     User    @relation(fields: [userId], references: [id])
  eventId  String
  event    Event   @relation(fields: [eventId], references: [id])
  attended Boolean @default(false) 

  @@unique([userId, eventId]) 
}

model Post {
  id        String   @id @default(uuid())
  title     String
  content   String   @db.Text
  imageUrl  String?
  createdAt DateTime @default(now())

  authorId String
  author   User   @relation(fields: [authorId], references: [id])
  comments Comment[]
}

model Comment {
  id        String   @id @default(uuid())
  content   String
  createdAt DateTime @default(now())
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
}